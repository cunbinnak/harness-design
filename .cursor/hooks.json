{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "matcher": "Write|StrReplace|Edit",
        "command": "py scripts/hooks/ide_bridge.py --ide cursor --event pre_edit",
        "failClosed": true
      },
      {
        "matcher": "Shell",
        "command": "py scripts/hooks/ide_bridge.py --ide cursor --event pre_shell",
        "failClosed": true
      }
    ],
    "stop": [
      {
        "command": "py scripts/hooks/ide_bridge.py --ide cursor --event post_agent",
        "failClosed": true
      }
    ]
  }
}
