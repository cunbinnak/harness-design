{
  "version": 4,
  "initial_state": "BOOTSTRAP",
  "states": {
    "BOOTSTRAP": {
      "description": "Khởi tạo, chưa có wave nào. Target reset sau /done-wave.",
      "allowed_commands": ["intake-requirement"],
      "allowed_spawn": false,
      "read_only_spawn_always": true
    },
    "INTAKE": {
      "description": "Intake done. /review-document loop revise theo feedback. /approve-document mark approved. /start-wave (gate approved=true) chuyen WAVE_OPEN.",
      "allowed_commands": ["intake-requirement", "review-document", "approve-document", "start-wave"],
      "allowed_spawn": true,
      "read_only_spawn_always": true,
      "agent_behavior": "flat_orchestration_by_main_agent"
    },
    "WAVE_OPEN": {
      "description": "Wave đã materialize agents + KG + MATRIX. Chờ start dev.",
      "allowed_commands": ["start-dev"],
      "allowed_spawn": false,
      "read_only_spawn_always": true
    },
    "DEV": {
      "description": "Sub-agent đang code 1 boundary trong polyrepo service folder.",
      "allowed_commands": ["review-dev"],
      "allowed_spawn": true,
      "read_only_spawn_always": true
    },
    "REVIEW_DEV": {
      "description": "Review agent self-review code. Internal loop: review → spawn fix sub-agent → re-review → pass.",
      "allowed_commands": ["dev-handoff"],
      "allowed_spawn": true,
      "read_only_spawn_always": true,
      "agent_behavior": "internal_review_fix_loop"
    },
    "DEV_HANDOFF": {
      "description": "Verify docker-compose + infra ready cho test agent chạy local.",
      "allowed_commands": ["test-plan"],
      "allowed_spawn": true,
      "read_only_spawn_always": true
    },
    "TEST_PLAN": {
      "description": "Sinh test-case-registry.md cho wave.",
      "allowed_commands": ["test-execute"],
      "allowed_spawn": true,
      "read_only_spawn_always": true
    },
    "TEST_EXECUTE": {
      "description": "Build service local + run auto test. Internal loop: fail → spawn fix → retest → pass. Auto-transition MANUAL_TEST khi test_result=pass.",
      "allowed_commands": [],
      "allowed_spawn": true,
      "read_only_spawn_always": true,
      "agent_behavior": "internal_test_fix_loop",
      "auto_transition_on": {"test_result": "pass"}
    },
    "MANUAL_TEST": {
      "description": "Wave shipped, UAT manual. Infra vẫn UP. /fix-bugs chain spawn fix+review sub-agent in-state.",
      "allowed_commands": ["fix-bugs", "end-wave"],
      "allowed_spawn": true,
      "read_only_spawn_always": true,
      "agent_behavior": "fix_bugs_chain_review"
    },
    "DONE": {
      "description": "Wave kết thúc, UAT signed. Chờ teardown hoặc CR amendment.",
      "allowed_commands": ["done-wave", "apply-cr"],
      "allowed_spawn": false,
      "read_only_spawn_always": true
    }
  },
  "transitions": [
    {
      "from": "BOOTSTRAP",
      "to": "INTAKE",
      "trigger": "intake-requirement",
      "evidence_required": {"step": 1}
    },
    {
      "from": "INTAKE",
      "to": "INTAKE",
      "trigger": "intake-requirement",
      "evidence_required": {"step": "2|3|4", "user_confirmed_prev": true}
    },
    {
      "from": "INTAKE",
      "to": "INTAKE",
      "trigger": "review-document",
      "evidence_required": {"feedback_processed": true},
      "note": "Revise loop. User cung cap feedback, agent revise doc. KHONG set approved."
    },
    {
      "from": "INTAKE",
      "to": "INTAKE",
      "trigger": "approve-document",
      "evidence_required": {"approved": true},
      "note": "User mark docs OK. Set approved=true in STATE. KHONG transition state. /start-wave gate check approved."
    },
    {
      "from": "INTAKE",
      "to": "WAVE_OPEN",
      "trigger": "start-wave",
      "evidence_required": {"approved": true, "wave_n": "any"}
    },
    {
      "from": "WAVE_OPEN",
      "to": "DEV",
      "trigger": "start-dev",
      "evidence_required": {"boundary": "any"}
    },
    {
      "from": "DEV",
      "to": "REVIEW_DEV",
      "trigger": "review-dev",
      "evidence_required": {}
    },
    {
      "from": "REVIEW_DEV",
      "to": "DEV_HANDOFF",
      "trigger": "dev-handoff",
      "evidence_required": {"coverage_pct": {"min": 80}, "review_result": "pass"}
    },
    {
      "from": "DEV_HANDOFF",
      "to": "TEST_PLAN",
      "trigger": "test-plan",
      "evidence_required": {"docker_compose_ok": true}
    },
    {
      "from": "TEST_PLAN",
      "to": "TEST_EXECUTE",
      "trigger": "test-execute",
      "evidence_required": {"test_cases_count": {"min": 1}}
    },
    {
      "from": "TEST_EXECUTE",
      "to": "MANUAL_TEST",
      "trigger": "_auto",
      "evidence_required": {"test_result": "pass"},
      "auto": true,
      "note": "Auto-transition khi test agent complete với test_result=pass, không command từ user"
    },
    {
      "from": "MANUAL_TEST",
      "to": "MANUAL_TEST",
      "trigger": "fix-bugs",
      "evidence_required": {"bug_id": "any"},
      "note": "In-state loop, agent chain fix + review"
    },
    {
      "from": "MANUAL_TEST",
      "to": "DONE",
      "trigger": "end-wave",
      "evidence_required": {"uat_signed": true, "no_open_bugs": true}
    },
    {
      "from": "DONE",
      "to": "BOOTSTRAP",
      "trigger": "done-wave",
      "evidence_required": {"teardown_ok": true}
    },
    {
      "from": "DONE",
      "to": "INTAKE",
      "trigger": "apply-cr",
      "evidence_required": {"cr_id": "any"},
      "note": "CR amendment chỉ từ DONE, không từ state khác"
    }
  ]
}
