{
  "version": 3,
  "description": "Index ràng buộc agent — nội dung áp dụng chung: .cursor/rules/harness-agent-discipline.mdc + KG. agent_roles = central doc-scope registry.",
  "always_apply_rule": ".cursor/rules/harness-agent-discipline.mdc",
  "kg_paths": {
    "shared": "knowledge-base/shared.knowledge-graph.yaml",
    "read_before_work": [
      "implementation.in_progress",
      "decisions",
      "discipline.do_not_repeat",
      "discipline.blockers",
      "learnings.gotchas"
    ],
    "write_after_work": [
      "decisions",
      "discipline.do_not_repeat",
      "discipline.blockers",
      "implementation.in_progress",
      "implementation.completed"
    ]
  },
  "rules": [
    {
      "id": 1,
      "key": "no_redo_completed_stage",
      "enforcement": [
        "gate",
        "rule"
      ]
    },
    {
      "id": 2,
      "key": "no_new_task_while_in_progress",
      "enforcement": [
        "rule",
        "kg"
      ]
    },
    {
      "id": 3,
      "key": "no_skip_blocker",
      "enforcement": [
        "rule",
        "kg"
      ]
    },
    {
      "id": 4,
      "key": "no_reopen_decided_adr",
      "enforcement": [
        "rule",
        "kg"
      ]
    },
    {
      "id": 5,
      "key": "no_duplicate_artifacts",
      "enforcement": [
        "rule",
        "gate"
      ]
    },
    {
      "id": 6,
      "key": "no_invent_boundary",
      "enforcement": [
        "rule",
        "gate"
      ]
    },
    {
      "id": 7,
      "key": "no_edit_outside_owned_paths",
      "enforcement": [
        "hook",
        "rule"
      ]
    },
    {
      "id": 21,
      "key": "no_edit_scripts",
      "enforcement": [
        "hook",
        "rule"
      ],
      "deny_prefix": "scripts/"
    },
    {
      "id": 8,
      "key": "no_cross_boundary_without_cr",
      "enforcement": [
        "rule",
        "gate"
      ]
    },
    {
      "id": 9,
      "key": "no_skip_handoff_on_stage_change",
      "enforcement": [
        "rule"
      ]
    },
    {
      "id": 10,
      "key": "must_log_knowledge",
      "enforcement": [
        "rule",
        "kg"
      ]
    },
    {
      "id": 11,
      "key": "must_log_do_not_repeat",
      "enforcement": [
        "rule",
        "kg"
      ]
    },
    {
      "id": 12,
      "key": "no_proceed_with_open_questions",
      "enforcement": [
        "rule",
        "kg"
      ]
    },
    {
      "id": 13,
      "key": "no_change_requirement_mid_impl",
      "enforcement": [
        "rule"
      ]
    },
    {
      "id": 14,
      "key": "must_log_bug_on_fix",
      "enforcement": [
        "gate"
      ]
    },
    {
      "id": 15,
      "key": "fix_then_review_retest",
      "enforcement": [
        "gate",
        "rule"
      ]
    },
    {
      "id": 16,
      "key": "no_manual_state_edit",
      "enforcement": [
        "hook"
      ]
    },
    {
      "id": 17,
      "key": "must_use_built_context",
      "enforcement": [
        "rule"
      ]
    },
    {
      "id": 18,
      "key": "spec_over_kg",
      "enforcement": [
        "rule"
      ]
    },
    {
      "id": 19,
      "key": "sync_features_in_flight",
      "enforcement": [
        "gate",
        "rule"
      ]
    },
    {
      "id": 20,
      "key": "spawn_only_allowed_stage",
      "enforcement": [
        "hook",
        "rule"
      ]
    },
    {
      "id": 22,
      "key": "pre_task_checklist",
      "enforcement": [
        "hook"
      ],
      "module": "scripts/hooks/task_check.py"
    }
  ],
  "agent_roles": {
    "_description": "Central doc-scope registry. Placeholders: {boundary} {wave}. build_command_prompt.py resolves these per agent based on its 'role' frontmatter field.",
    "_shared_always": [
      "knowledge-base/shared.knowledge-graph.yaml",
      "harness/STATE.json"
    ],
    "intake:requirement-analyst": {
      "purpose": "Bước 1/4 intake — phân tích yêu cầu",
      "reads": [
        "docs/architecture/PROJECT.md",
        "docs/architecture/feat/**"
      ],
      "writes": [
        "docs/architecture/PROJECT.md",
        "docs/architecture/feat/FEAT-*.md"
      ]
    },
    "intake:business-analyst": {
      "purpose": "Bước 2/4 intake — AC + business rules",
      "reads": [
        "docs/architecture/PROJECT.md",
        "docs/architecture/feat/**"
      ],
      "writes": [
        "docs/architecture/feat/FEAT-*.md",
        "docs/architecture/PROJECT.md"
      ]
    },
    "intake:solution-architect": {
      "purpose": "Bước 3/4 intake — ADR + per-boundary architecture",
      "reads": [
        "docs/architecture/PROJECT.md",
        "docs/architecture/feat/**"
      ],
      "writes": [
        "docs/architecture/adr/ADR-*.md",
        "docs/architecture/hld/hld-*.md",
        "docs/architecture/api/api-*.md",
        "docs/architecture/data-model/data-model-*.md",
        "docs/architecture/ux/ux-*.md",
        "docs/architecture/integrations-matrix.md",
        "docs/architecture/infra/**"
      ]
    },
    "intake:program-planner": {
      "purpose": "Bước 4/4 intake — roadmap + waves + materialize agents",
      "reads": [
        "docs/architecture/PROJECT.md",
        "docs/architecture/feat/**",
        "docs/architecture/integrations-matrix.md"
      ],
      "writes": [
        "docs/plans/project/waves-roadmap.md",
        "docs/plans/project/agent-roster.md",
        "docs/plans/waves/**"
      ]
    },
    "review:document": {
      "purpose": "Gate review tài liệu sau intake",
      "reads": [
        "docs/architecture/**",
        "docs/plans/**",
        "harness/SERVICE-BOUNDARY-MATRIX.json"
      ],
      "writes": []
    },
    "dev:backend": {
      "purpose": "BE boundary dev — implement code + unit test",
      "reads": [
        "docs/architecture/PROJECT.md",
        "docs/plans/waves/{wave}/wave.md",
        "docs/architecture/hld/hld-{boundary}.md",
        "docs/architecture/api/api-{boundary}.md",
        "docs/architecture/data-model/data-model-{boundary}.md",
        "docs/architecture/integrations-matrix.md",
        "knowledge-base/{boundary}.knowledge-graph.yaml"
      ],
      "writes": [
        "services/{boundary}/**",
        "knowledge-base/{boundary}.knowledge-graph.yaml"
      ]
    },
    "dev:frontend": {
      "purpose": "FE surface dev — implement UI + API integration",
      "reads": [
        "docs/architecture/PROJECT.md",
        "docs/plans/waves/{wave}/wave.md",
        "docs/architecture/ux/ux-{boundary}.md",
        "docs/architecture/api/api-*.md",
        "docs/architecture/integrations-matrix.md",
        "knowledge-base/{boundary}.knowledge-graph.yaml"
      ],
      "writes": [
        "services/{boundary}/**",
        "knowledge-base/{boundary}.knowledge-graph.yaml"
      ]
    },
    "review:backend": {
      "purpose": "Self-review code BE boundary — coverage, lint, security",
      "reads": [
        "docs/architecture/PROJECT.md",
        "services/{boundary}/**",
        "docs/architecture/hld/hld-{boundary}.md",
        "docs/architecture/api/api-{boundary}.md",
        "knowledge-base/{boundary}.knowledge-graph.yaml"
      ],
      "writes": [
        "knowledge-base/{boundary}.knowledge-graph.yaml"
      ]
    },
    "review:frontend": {
      "purpose": "Self-review code FE — coverage, a11y, UX khớp wireframe",
      "reads": [
        "docs/architecture/PROJECT.md",
        "services/{boundary}/**",
        "docs/architecture/ux/ux-{boundary}.md",
        "knowledge-base/{boundary}.knowledge-graph.yaml"
      ],
      "writes": [
        "knowledge-base/{boundary}.knowledge-graph.yaml"
      ]
    },
    "fix:backend": {
      "purpose": "Fix bugs BE boundary",
      "reads": [
        "docs/architecture/PROJECT.md",
        "tracking/waves/{wave}/bugs/**",
        "services/{boundary}/**",
        "docs/architecture/hld/hld-{boundary}.md",
        "docs/architecture/api/api-{boundary}.md",
        "knowledge-base/{boundary}.knowledge-graph.yaml"
      ],
      "writes": [
        "services/{boundary}/**",
        "knowledge-base/{boundary}.knowledge-graph.yaml"
      ]
    },
    "fix:frontend": {
      "purpose": "Fix bugs FE",
      "reads": [
        "docs/architecture/PROJECT.md",
        "tracking/waves/{wave}/bugs/**",
        "services/{boundary}/**",
        "docs/architecture/ux/ux-{boundary}.md",
        "knowledge-base/{boundary}.knowledge-graph.yaml"
      ],
      "writes": [
        "services/{boundary}/**",
        "knowledge-base/{boundary}.knowledge-graph.yaml"
      ]
    },
    "dev-handoff": {
      "purpose": "Gate dev → QA: coverage + infra + handoff doc",
      "reads": [
        "docs/plans/waves/{wave}/wave.md",
        "docs/architecture/infra/**",
        "handoff/{wave}.md"
      ],
      "writes": [
        "handoff/{wave}.md"
      ]
    },
    "test-plan": {
      "purpose": "Lập kế hoạch test — tạo test case file",
      "reads": [
        "handoff/{wave}.md",
        "docs/architecture/feat/**",
        "docs/architecture/api/**",
        "docs/architecture/ux/**"
      ],
      "writes": [
        "tracking/waves/{wave}/test-cases.md"
      ]
    },
    "test-execute": {
      "purpose": "Chạy test — không đọc source code",
      "reads": [
        "tracking/waves/{wave}/test-cases.md",
        "handoff/{wave}.md",
        "docs/architecture/infra/**",
        "docs/architecture/ux/**"
      ],
      "writes": [
        "tracking/waves/{wave}/test-results.md",
        "tracking/waves/{wave}/bugs/BUG-*.md"
      ]
    },
    "cross-boundary-review": {
      "purpose": "Reviewer xuyên boundary — integration, security, consistency",
      "reads": [
        "handoff/{wave}.md",
        "docs/architecture/integrations-matrix.md",
        "tracking/waves/{wave}/test-results.md",
        "harness/SERVICE-BOUNDARY-MATRIX.json"
      ],
      "writes": []
    },
    "release": {
      "purpose": "Tạo release notes",
      "reads": [
        "docs/plans/waves/{wave}/wave.md",
        "handoff/{wave}.md",
        "tracking/waves/{wave}/test-results.md",
        "tracking/waves/{wave}/bugs/**"
      ],
      "writes": [
        "tracking/waves/{wave}/release-notes.md"
      ]
    },
    "end-wave": {
      "purpose": "Soft close — ship wave, signal manual UAT phase; infra stays UP",
      "reads": [
        "handoff/{wave}.md",
        "tracking/waves/{wave}/release-notes.md",
        "tracking/waves/{wave}/test-results.md"
      ],
      "writes": [
        "handoff/{wave}.md",
        "tracking/waves/{wave}/manual-test-log.md"
      ]
    },
    "apply-cr": {
      "purpose": "Phân tích CR đã duyệt → prepare intake amendment",
      "reads": [
        "tracking/change-requests/**",
        "docs/architecture/PROJECT.md",
        "docs/plans/project/**"
      ],
      "writes": [
        "tracking/change-requests/**"
      ]
    },
    "start-wave": {
      "purpose": "Mở wave — kiểm tra plan, copy handoff template",
      "reads": [
        "docs/plans/project/waves-roadmap.md",
        "docs/plans/waves/{wave}/wave.md",
        "docs/plans/project/agent-roster.md"
      ],
      "writes": [
        "handoff/{wave}.md"
      ]
    },
    "done-wave": {
      "purpose": "Hard close — teardown infra + reset STATE for next wave",
      "reads": [
        "handoff/{wave}.md",
        "tracking/waves/{wave}/release-notes.md",
        "tracking/waves/{wave}/manual-test-log.md"
      ],
      "writes": [
        "handoff/{wave}.md"
      ]
    }
  },
  "memory_layers": {
    "ephemeral": "harness/STATE.json",
    "durable_specs": "docs/",
    "shared_memory": "knowledge-base/*.knowledge-graph.yaml",
    "continuity": "handoff/",
    "evidence": "tracking/"
  },
  "context_build": {
    "include_knowledge_base": true,
    "include_handoff_when_set": true,
    "excluded_paths_globs": []
  }
}
