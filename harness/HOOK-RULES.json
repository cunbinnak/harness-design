{
  "version": 2,
  "hooks": {
    "owned_paths": {
      "when": "pre_edit",
      "severity": "block",
      "description": "Chỉ sửa owned_paths hoặc allowlist orchestrator — không sửa scripts/harness config",
      "allowlist_prefixes": [
        "docs/",
        "handoff/",
        "tracking/",
        "knowledge-base/",
        "agents/",
        "commands/"
      ],
      "denylist_prefixes": [
        "scripts/",
        "harness/STATE.json",
        "harness/STATE-MACHINE.json",
        "harness/COMMAND-GATES.json",
        "harness/HOOK-RULES.json",
        ".cursor/hooks.json"
      ]
    },
    "return_schema": {
      "when": "post_agent",
      "severity": "block",
      "description": "Message cuối sub-agent phải là JSON RETURN SCHEMA",
      "required_fields": [
        "completed",
        "deferred",
        "needs_review",
        "files_changed",
        "build",
        "lint",
        "test"
      ],
      "failure_mode": "FM-012"
    },
    "transition_gate": {
      "when": "pre_transition",
      "severity": "block",
      "description": "Bắt buộc gate_runner.check_command — không complete thủ công STATE",
      "runner": "gate_runner.check_command"
    },
    "workflow_allowed_next": {
      "when": "pre_complete_command",
      "severity": "block",
      "description": "Command phải nằm trong workflow.allowed_next — từ chối và DỪNG; không sửa STATE / không lách bước (ide_bridge pre_shell + harness_policy)"
    },
    "spawn_active": {
      "when": "pre_spawn",
      "severity": "block",
      "description": "spawn.active phải null trước spawn-begin"
    },
    "wave_open": {
      "when": "pre_command",
      "severity": "block",
      "description": "Wave chưa completed (trừ intake / duyệt plan trước khi mở wave)",
      "except_commands": [
        "intake-requirement",
        "review-document",
        "apply-cr"
      ]
    },
    "dev_agent_spawn": {
      "when": "pre_spawn",
      "severity": "block",
      "description": "start-dev/fix-bugs/review-dev: file agent dev phải tồn tại trên disk",
      "commands": [
        "start-dev",
        "fix-bugs",
        "review-dev"
      ]
    },
    "discipline_blockers": {
      "when": "pre_complete_command",
      "severity": "block",
      "description": "Không harness complete khi shared KG có discipline.blockers",
      "kg_path": "knowledge-base/shared.knowledge-graph.yaml",
      "except_commands": []
    },
    "discipline_kg_return": {
      "when": "post_agent",
      "severity": "block",
      "description": "Sub-agent có thay đổi phải ghi kg_appended hoặc deferred.tracked_in",
      "requires_kg_when": [
        "files_changed",
        "completed"
      ]
    },
    "spawn_stage": {
      "when": "pre_spawn",
      "severity": "block",
      "description": "Spawn chỉ khi STATE.stage thuộc spawn.allowed_stages"
    },
    "task_checklist": {
      "when": "multi",
      "severity": "block",
      "description": "12 câu checklist task — feature, stage, agent, boundary, owned_paths, KG, blockers, why",
      "block_on_warn": [],
      "checks": [
        "feature",
        "feature_stage",
        "agent_assigned",
        "boundary_resolve",
        "owned_paths",
        "task_in_stage",
        "kg_completed",
        "kg_in_progress",
        "blockers",
        "decisions",
        "do_not_repeat",
        "why_linked"
      ]
    }
  },
  "triggers": {
    "session_start": {
      "description": "Đầu session — snapshot STATE + KG cảnh báo (non-blocking)",
      "hooks": [
        "task_checklist"
      ],
      "maps_to": "session_start",
      "block": false
    },
    "pre_task_check": {
      "description": "Trước spawn / build_command_prompt step — full checklist",
      "hooks": [
        "task_checklist",
        "spawn_stage",
        "spawn_active"
      ],
      "maps_to": "pre_spawn",
      "block": true
    },
    "pre_write_check": {
      "description": "Trước sửa file — owned_paths + checklist",
      "hooks": [
        "owned_paths",
        "task_checklist"
      ],
      "maps_to": "pre_edit",
      "block": true
    },
    "pre_state_transition": {
      "description": "Trước harness complete / apply_transition",
      "hooks": [
        "workflow_allowed_next",
        "transition_gate",
        "discipline_blockers",
        "task_checklist"
      ],
      "maps_to": "pre_shell",
      "block": true
    },
    "post_state_transition": {
      "description": "Sau complete — log checkpoint checklist",
      "hooks": [
        "task_checklist"
      ],
      "maps_to": "workflow_engine",
      "block": false
    },
    "post_task_log": {
      "description": "Sau sub-agent — RETURN SCHEMA + kg_appended",
      "hooks": [
        "return_schema",
        "discipline_kg_return",
        "task_checklist"
      ],
      "maps_to": "post_agent",
      "block": true
    },
    "on_change_detected": {
      "description": "Khi RETURN.files_changed — verify path + feature link",
      "hooks": [
        "task_checklist"
      ],
      "maps_to": "post_agent",
      "block": true
    }
  },
  "implementation": "scripts/hooks/README.md",
  "command_evidence_schema": {
    "review-document": {
      "required": [
        "approved"
      ],
      "types": {
        "approved": "boolean"
      }
    },
    "start-wave": {
      "required": [],
      "optional": [
        "wave_id",
        "wave_title"
      ]
    },
    "apply-cr": {
      "required": [
        "cr_id"
      ],
      "optional": [
        "cr_path"
      ]
    },
    "intake-requirement": {
      "optional": [
        "intake_mode",
        "change_summary",
        "cr_id"
      ]
    },
    "dev-handoff": {
      "required": [
        "coverage_pct",
        "handoff_ready"
      ],
      "optional": [
        "coverage_fe_pct"
      ]
    },
    "test-execute": {
      "required": [
        "test_result"
      ],
      "in": {
        "test_result": [
          "pass",
          "fail"
        ]
      }
    },
    "release": {
      "required": [
        "release_ok"
      ]
    },
    "end-wave": {
      "required": [
        "end_wave_ok"
      ]
    },
    "start-dev": {
      "required": [
        "features_in_flight",
        "boundaries_in_flight"
      ],
      "optional": [
        "boundary_id"
      ],
      "list_min": 1
    },
    "review-dev": {
      "optional": [
        "boundary_id"
      ]
    },
    "fix-bugs": {
      "optional": [
        "boundary_id"
      ]
    },
    "done-wave": {
      "required": [
        "done_wave_ok"
      ]
    }
  }
}
